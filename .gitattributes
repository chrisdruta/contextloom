# Force LF on checkout everywhere. Windows runners default to
# core.autocrlf=true, which checked out every file with CRLF and made
# Biome's LF formatting flag all 87 files as misformatted in CI.
* text=auto eol=lf

# Binaries — never normalize
*.png binary
*.jpg binary
*.gif binary
*.woff binary
*.woff2 binary
*.vsix binary
