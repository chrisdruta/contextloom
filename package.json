{
  "name": "contextloom",
  "displayName": "ContextLoom — Docs & Agent Context Graph",
  "description": "See how your repository's context is woven together. Navigable knowledge graph for Markdown docs and AI-agent configuration.",
  "version": "0.1.0",
  "publisher": "chrisdruta",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/chrisdruta/contextloom.git"
  },
  "homepage": "https://github.com/chrisdruta/contextloom#readme",
  "bugs": {
    "url": "https://github.com/chrisdruta/contextloom/issues"
  },
  "files": [
    "dist/*.js",
    "media/**",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "PRIVACY.md",
    "SECURITY.md"
  ],
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["Visualization", "Other"],
  "keywords": [
    "markdown",
    "graph",
    "documentation",
    "AGENTS.md",
    "CLAUDE.md",
    "agent context",
    "knowledge graph"
  ],
  "activationEvents": [
    "onCommand:contextloom.openGraph",
    "onCommand:contextloom.openGraphForFolder",
    "onCommand:contextloom.focusCurrentFile",
    "onCommand:contextloom.findLooseThreads",
    "onCommand:contextloom.refreshGraph",
    "onCommand:contextloom.exportGraph",
    "onCommand:contextloom.showAgentContext",
    "onView:contextloom.graphRoots",
    "onView:contextloom.looseThreads",
    "onView:contextloom.agentsSkills",
    "onView:contextloom.graphOutline",
    "onWebviewPanel:contextloom.loom"
  ],
  "main": "./dist/extension.js",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "Indexing and graph work in limited mode; Export and LLM features disabled.",
      "restrictedConfigurations": [
        "contextloom.followSymlinks",
        "contextloom.include",
        "contextloom.exclude"
      ]
    }
  },
  "contributes": {
    "commands": [
      {
        "command": "contextloom.openGraph",
        "title": "ContextLoom: Open Graph",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "contextloom.openGraphForFolder",
        "title": "ContextLoom: Open Graph for Folder",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "contextloom.focusCurrentFile",
        "title": "ContextLoom: Focus on Current File",
        "icon": "$(target)"
      },
      {
        "command": "contextloom.findLooseThreads",
        "title": "ContextLoom: Find Loose Threads"
      },
      {
        "command": "contextloom.refreshGraph",
        "title": "ContextLoom: Refresh Graph",
        "icon": "$(refresh)"
      },
      {
        "command": "contextloom.exportGraph",
        "title": "ContextLoom: Export Graph (JSON)"
      },
      {
        "command": "contextloom.showAgentContext",
        "title": "ContextLoom: Show Applicable Agent Context",
        "icon": "$(law)"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "contextloom.openGraphForFolder",
          "when": "explorerResourceIsFolder",
          "group": "navigation@90"
        },
        {
          "command": "contextloom.showAgentContext",
          "when": "!explorerResourceIsFolder",
          "group": "navigation@91"
        }
      ],
      "editor/title": [
        {
          "command": "contextloom.focusCurrentFile",
          "when": "resourceExtname == .md",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "contextloom.showAgentContext",
          "group": "navigation@91"
        }
      ],
      "view/title": [
        {
          "command": "contextloom.refreshGraph",
          "when": "view == contextloom.graphRoots || view == contextloom.looseThreads || view == contextloom.agentsSkills || view == contextloom.graphOutline",
          "group": "navigation"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "contextloom",
          "title": "ContextLoom",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "contextloom": [
        {
          "id": "contextloom.graphRoots",
          "name": "Graph Roots"
        },
        {
          "id": "contextloom.looseThreads",
          "name": "Loose Threads — orphans & broken links"
        },
        {
          "id": "contextloom.agentsSkills",
          "name": "Agents & Skills"
        },
        {
          "id": "contextloom.graphOutline",
          "name": "Graph Outline"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "contextloom.agentsSkills",
        "contents": "No agents, skills, commands, or rules found.\nResources under .claude/ and .cursor/rules/ appear here after indexing.\n[Open Graph](command:contextloom.openGraph)"
      }
    ],
    "configuration": {
      "title": "ContextLoom",
      "properties": {
        "contextloom.roots": {
          "type": "array",
          "maxItems": 100,
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Saved graph roots (workspace-relative). Empty = workspace root."
        },
        "contextloom.include": {
          "type": "array",
          "maxItems": 200,
          "items": {
            "type": "string"
          },
          "default": [
            "**/*.md",
            "**/*.mdc",
            "**/AGENTS.md",
            "**/CLAUDE.md",
            "**/SKILL.md",
            "**/.claude/skills/**",
            "**/.claude/settings.json",
            "**/.claude/settings.local.json",
            "**/.cursorrules"
          ],
          "description": "Include globs for discovery."
        },
        "contextloom.exclude": {
          "type": "array",
          "maxItems": 200,
          "items": {
            "type": "string"
          },
          "default": [
            "**/node_modules/**",
            "**/.git/**",
            "**/dist/**",
            "**/build/**",
            "**/out/**",
            "**/vendor/**",
            "**/coverage/**"
          ],
          "description": "Exclude globs (additive to gitignore/VS Code excludes)."
        },
        "contextloom.respectGitignore": {
          "type": "boolean",
          "default": true,
          "description": "Honor .gitignore chains during discovery."
        },
        "contextloom.followSymlinks": {
          "type": "boolean",
          "default": false,
          "description": "Follow symlinks during discovery."
        },
        "contextloom.wikiLinks.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Parse [[wiki links]]."
        },
        "contextloom.wikiLinks.resolution": {
          "type": "string",
          "enum": ["shortest-unique", "root-relative"],
          "default": "shortest-unique",
          "description": "Wiki-link target resolution strategy."
        },
        "contextloom.graph.showExternalLinks": {
          "type": "boolean",
          "default": false,
          "description": "Render external URLs as nodes vs collapsed badge."
        },
        "contextloom.graph.maxNodes": {
          "type": "number",
          "maximum": 10000,
          "default": 3000,
          "description": "Maximum nodes sent to the graph view."
        },
        "contextloom.graph.renderer": {
          "type": "string",
          "enum": ["cytoscape", "canvas"],
          "default": "cytoscape",
          "description": "Graph renderer: cytoscape (fcose layout, richer interactions) or canvas (lightweight fallback). Reopen the Loom View after changing."
        },
        "contextloom.diagnostics.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Publish broken-link diagnostics to Problems panel."
        },
        "contextloom.limits.maxFiles": {
          "type": "number",
          "maximum": 100000,
          "default": 20000,
          "description": "Hard indexing cap (explicit skip report)."
        },
        "contextloom.limits.maxFileSizeKb": {
          "type": "number",
          "maximum": 10240,
          "default": 1024,
          "description": "Skip files larger than this many KB."
        },
        "contextloom.agents.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Recognize agent instruction formats (AGENTS.md, CLAUDE.md)."
        },
        "contextloom.agents.agentsMdMode": {
          "type": "string",
          "enum": ["nearest", "merge"],
          "default": "nearest",
          "description": "AGENTS.md consumer semantics: nearest-wins per the agents.md spec, or merge (Cursor/VS Code style — nested files all apply)."
        },
        "contextloom.agents.formats": {
          "type": "array",
          "maxItems": 20,
          "items": {
            "type": "string"
          },
          "default": ["agents-md", "claude", "cursor"],
          "description": "Enabled agent-format adapters (agents-md, claude, cursor)."
        }
      }
    }
  },
  "scripts": {
    "build": "bun run scripts/build.ts",
    "watch": "bun run scripts/build.ts --watch",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p webview-ui/tsconfig.json",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "vsce package --no-dependencies",
    "vscode:prepublish": "bun run build",
    "test:integration": "bun run build && bun run scripts/build-tests.ts && vscode-test",
    "bench:renderers": "bun run scripts/bench-renderers.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/cytoscape": "^3.31.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.10.0",
    "@types/vscode": "^1.90.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.2.1",
    "esbuild": "^0.28.1",
    "mocha": "^11.7.6",
    "ovsx": "^1.0.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "cytoscape": "^3.34.0",
    "cytoscape-fcose": "^2.2.0",
    "github-slugger": "^2.0.0",
    "graphology": "^0.25.4",
    "graphology-types": "^0.24.7",
    "ignore": "^6.0.2",
    "mdast-util-from-markdown": "^2.0.2",
    "mdast-util-frontmatter": "^2.0.1",
    "mdast-util-gfm": "^3.0.0",
    "micromark-extension-frontmatter": "^2.0.0",
    "micromark-extension-gfm": "^3.0.0",
    "picomatch": "^4.0.2",
    "preact": "^10.25.2",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  }
}
